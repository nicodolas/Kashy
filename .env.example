# Kashy — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.

# Override the OpenRouter API key (alternative to `kashy config set-key`)
# OPENROUTER_API_KEY=sk-or-...

# Override the config file path (useful for development/testing)
# KASHY_CONFIG=/path/to/custom/config.toml
